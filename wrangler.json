{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cfduty",
  "main": "src/worker.js",
  "compatibility_date": "2025-07-20",
  "workers_dev": false,
  "observability": {
    "enabled": true
  },
  "workflows": [
    {
      "name": "cfduty-workflow",
      "binding": "WORKFLOW",
      "class_name": "AlertWorkflow"
    }
  ],
  "env": {
    "dev": {
      "name": "cfduty-dev",
      "compatibility_date": "2025-07-20",
      "workflows": [
        {
          "name": "cfduty-workflow-dev",
          "binding": "WORKFLOW",
          "class_name": "AlertWorkflow"
        }
      ]
    }
  }
}

